# ─── Server ────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173

# ─── Database ──────────────────────────────────────────────
MONGO_URI=mongodb://127.0.0.1:27017/heartcave

# ─── Auth ──────────────────────────────────────────────────
# Use long random strings in production (e.g. `openssl rand -hex 48`)
JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ─── AI Provider ───────────────────────────────────────────
# Supported: "rules" (default, no key needed), "openai"
AI_PROVIDER=rules
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ─── Seed admin (used by seed script) ──────────────────────
ADMIN_EMAIL=admin@heartcave.app
ADMIN_PASSWORD=Admin@12345


# ── Feedback email notifications (Nodemailer) ──
# Optional in development: if unset, feedback still saves; the email is skipped.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=youraddress@gmail.com
SMTP_PASS=your_app_password          # e.g. a Gmail App Password, NOT your login password
SMTP_FROM=HeartCave <youraddress@gmail.com>
FEEDBACK_NOTIFY_EMAIL=owner@example.com   # where notifications are sent (defaults to SMTP_USER)